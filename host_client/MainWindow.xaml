<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CeRemote.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CeRemote">

    <Grid RowSpacing="6" Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Connection bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Device" VerticalAlignment="Center" />
            <TextBox x:Name="HostBox" Text="192.168.0.39" Width="160" />
            <Button x:Name="ConnectButton" Content="Connect" Click="OnConnectClick" />
            <TextBlock x:Name="StatusText" Text="disconnected" VerticalAlignment="Center"
                       Foreground="Gray" />
        </StackPanel>

        <!-- Body: VNC viewer (left) + file manager (right) -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="Black" BorderBrush="Gray" BorderThickness="1">
                <Image x:Name="ScreenImage" Stretch="Uniform"
                       PointerPressed="OnScreenPointerPressed"
                       PointerReleased="OnScreenPointerReleased"
                       PointerMoved="OnScreenPointerMoved" />
            </Border>

            <Grid Grid.Column="1" RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                    <Button x:Name="UpButton" Content="Up" Click="OnUpClick" />
                    <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefreshClick" />
                </StackPanel>

                <TextBox Grid.Row="1" x:Name="PathBox" Text="\SDMMC Disk"
                         KeyDown="OnPathKeyDown" />

                <ListView Grid.Row="2" x:Name="FileList"
                          DoubleTapped="OnFileDoubleTapped"
                          BorderBrush="Gray" BorderThickness="1">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:CeEntry">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Glyph}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{x:Bind SizeText}"
                                           Foreground="Gray" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6">
                    <Button x:Name="DownloadButton" Content="Download" Click="OnDownloadClick" />
                    <Button x:Name="UploadButton" Content="Upload" Click="OnUploadClick" />
                </StackPanel>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" x:Name="LogText" Text="" Foreground="Gray"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</Window>
